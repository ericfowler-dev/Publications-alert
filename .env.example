# Server Configuration
PORT=3000
NODE_ENV=production

# Base URL for email links (no trailing slash)
# Local development: http://localhost:3000
# Production: https://your-app-name.onrender.com
BASE_URL=http://localhost:3000

# Admin Login Credentials
# IMPORTANT: Change these before deploying!
ADMIN_USER=admin
ADMIN_PASS=changeme

# Session secret (random string for cookie signing)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Persistent paths. Leave blank to use /data in production and the repo folder locally.
DATA_DIR=
DB_PATH=
UPLOAD_DIR=
EXPORT_DIR=

# Distribution sending controls
EMAIL_SEND_CONCURRENCY=3
EMAIL_SEND_BATCH_DELAY_MS=250
MAX_UPLOAD_SIZE_MB=25
LOG_ARCHIVE_DAYS=180
LOG_ARCHIVE_ENABLED=true

# SMTP Configuration
# If not set, emails will be logged to console only.
#
# Recommended services:
#   SendGrid: https://sendgrid.com (free tier: 100 emails/day)
#   Mailgun: https://mailgun.com
#   Amazon SES: https://aws.amazon.com/ses/
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.your-api-key-here
#   SMTP_FROM=publications@yourdomain.com
#
# Gmail example (requires App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASS=your-app-password
#   SMTP_FROM=your-email@gmail.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=publications@psi.com
